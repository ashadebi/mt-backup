# mt-backup environment variables — copy to data/.env and customize
#
# Encryption key for SSH passwords stored in SQLite.
# Generate a new one with:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MT_FERNET_KEY=

# Session signing key for FastAPI SessionMiddleware.
# Generate a new one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
MT_SECRET_KEY=

# Bootstrap admin (always active — cannot be deleted via UI).
# Recommended: change from default and set a strong password.
# Generate hash with:  python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(rounds=12)).decode())"
MT_ADMIN_USERNAME=admin
MT_ADMIN_PASSWORD_HASH=

# Optional: token for cron webhook (POST /api/backup/run with X-Cron-Token header)
MT_CRON_TOKEN=

# Data and backup directories (inside container)
MT_DATA_DIR=/app/data
MT_BACKUP_DIR=/app/backups